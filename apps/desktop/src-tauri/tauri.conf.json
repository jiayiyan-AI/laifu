{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "来福",
  "version": "0.0.1",
  "mainBinaryName": "Laifu",
  "identifier": "com.lingxi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @lingxi/desktop dev:front",
    "beforeBuildCommand": "pnpm --filter @lingxi/desktop build:front"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/rclone"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["laifu"]
      }
    }
  }
}
