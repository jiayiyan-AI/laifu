{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "home-remote",
  "description": "home 窗口加载远程 web 首页；仅允许 OAuth、云文件下载、显示同步状态面板和显示 settings 窗口。它不能读取或修改同步、认证与 settings 业务状态。",
  "windows": ["home"],
  "remote": {
    "urls": ["http://localhost:3000/*", "https://app-lingxi-dev-gateway.azurewebsites.net/*", "https://laifu.uncagedai.org/*"]
  },
  "permissions": ["allow-open-oauth-in-browser", "allow-download-cloud-file", "allow-show-sync-flyout-from-home", "allow-show-settings-window-from-home"]
}
