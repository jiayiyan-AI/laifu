{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "来福首页（home）+ 同步盘壳（sync）+ 登录（login）三窗口的默认权限集：前端 invoke 自定义命令 + listen 'authed' 事件 + 窗口/ webview 基础能力。",
  "windows": ["home", "sync", "login"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "opener:default",
    "deep-link:default",
    "allow-app-commands"
  ]
}
