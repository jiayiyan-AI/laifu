{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "bundled flyout、settings 与 login surface 的默认权限集：本地命令、事件和窗口/webview 基础能力。远程 home 使用独立的最小权限 capability。",
  "windows": ["flyout", "settings", "login"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "opener:default",
    "deep-link:default",
    "allow-app-commands"
  ]
}
