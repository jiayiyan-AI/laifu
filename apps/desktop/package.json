{
  "name": "@lingxi/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:front": "vite",
    "build:front": "vite build",
    "dev": "LAIFU_CHANNEL=dev tauri dev --features app --config src-tauri/tauri.conf.dev.json",
    "dev:canary": "LAIFU_CHANNEL=canary tauri dev --features app --config src-tauri/tauri.conf.canary.json",
    "dev:stable": "LAIFU_CHANNEL=stable tauri dev --features app",
    "build": "LAIFU_CHANNEL=stable tauri build --features app",
    "build:canary": "LAIFU_CHANNEL=canary tauri build --features app --config src-tauri/tauri.conf.canary.json",
    "build:dev": "LAIFU_CHANNEL=dev tauri build --features app --config src-tauri/tauri.conf.dev.json",
    "lint": "tsc --noEmit",
    "core:build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "core:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "core:check": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@lingxi/shared": "workspace:*",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.11",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@lingxi/atom": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react-router": "^7.18.1",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.4"
  }
}
