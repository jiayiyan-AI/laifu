PORT=9000
SUPABASE_URL=http://localhost:54421
SUPABASE_SERVICE_ROLE_KEY=

# Provisioner mode: 'local' (dev) | 'azure' (prod)
PROVISIONER=local
LOCAL_CONTAINER_URL=http://localhost:8080

# Azure (仅 PROVISIONER=azure 时需要)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-lingxi-dev
AZURE_LOCATION=eastasia
AZURE_CONTAINER_APPS_ENV=cae-lingxi-dev
AZURE_STORAGE_ACCOUNT=stlingxidev
AZURE_ACR_LOGIN_SERVER=acrlingxidev.azurecr.io
HERMES_IMAGE_TAG=hermes-base:v1

# Session
SESSION_SECRET=change-me-to-32-byte-random-hex
SESSION_COOKIE_NAME=lingxi_sid
SESSION_TTL_HOURS=168

# === Auth ===

# gateway 自己对外的入口,用于构造 OAuth redirect_uri。
# 本地开发: http://localhost:9000 (gateway 直连,Google 把浏览器 302 到这里)
# 云上:     https://<your-domain> (跟前端同域,反代 /api/* 转给 gateway)
PUBLIC_BASE_URL=http://localhost:9000

# 前端应用入口,OAuth 成功后浏览器 302 跳回这里 + /desktop。
# 本地开发: http://localhost:3000 (Vite)
# 云上:     跟 PUBLIC_BASE_URL 同域,可填空让 gateway 发相对路径
FRONTEND_BASE_URL=http://localhost:3000

# === OAuth providers ===
# 一个 provider 的 CLIENT_ID + CLIENT_SECRET 都填了,就自动启用;
# 至少要有一个 provider 启用(否则 gateway 启动报错)。

# Google OAuth (https://console.cloud.google.com)
#   APIs & Services → Credentials → Create OAuth Client ID → Web application
#   Authorized JavaScript origins:  http://localhost:3000 (前端)
#   Authorized redirect URIs:       http://localhost:9000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
