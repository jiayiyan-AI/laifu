# =============================================================================
# Gateway env — 复制为 .env.local 后填值
# =============================================================================
# 真相源约定:
#   - dev 用哪些值由本文件注释指引, 实际值填到 .env.local (gitignored)
#   - prod 用哪些值由 infra/bicep/main.bicep 的 appSettings + Key Vault 决定
#   - 名字不要漂移: 本文件加新 env 时, 同步加到 main.bicep
# 跨环境总览: 见 docs/environments.md
# =============================================================================


# ── Server ──────────────────────────────────────────────────────────────
# dev:  9000 (跟 Vite proxy target 对齐, scripts/dev-check.sh 也检查这个)
# prod: 8080 (App Service 注入, bicep 已写死)
PORT=9000


# ── Supabase ────────────────────────────────────────────────────────────
# 两种 dev 模式 (二选一):
#
# [A] 本地 supabase start (离线友好, 但要装 supabase CLI + Docker)
#     cd infra && supabase start
#     注意: laifu 的所有 supabase 端口已 +100 (api 54421 / db 54422 / studio 54423 ...),
#     避免和其他本地项目 (e.g. dumare) 抢占默认 54321 端口段.
#     SUPABASE_URL=http://localhost:54421
#     SUPABASE_SERVICE_ROLE_KEY=<supabase start 输出里的 service_role key>
#
# [B] Supabase Cloud 的 dev project (推荐多设备/手机测试时, 不折腾本地)
#     Dashboard → 建一个独立 dev 项目 (跟 prod 物理隔离)
#     SUPABASE_URL=https://<dev-ref>.supabase.co
#     SUPABASE_SERVICE_ROLE_KEY=<dashboard → Settings → API → service_role>
#
# prod: KV secret supabase-url / supabase-service-role-key, bicep 灌入
SUPABASE_URL=http://localhost:54421
SUPABASE_SERVICE_ROLE_KEY=


# ── Provisioner ─────────────────────────────────────────────────────────
# dev:  local — 调本地单实例 hermes (scripts/dev-hermes.sh 起的 docker)
# prod: azure — 每个用户起独立 Container App (SDK 调用)
PROVISIONER=local

# local 模式专用 (PROVISIONER=local 时被读, prod 不需要)
LOCAL_CONTAINER_URL=http://localhost:8080


# ── Azure (PROVISIONER=azure 时才需要; dev 一般留空) ────────────────────
# prod: 这些非敏感值由 bicep 输出 + appSettings 灌入, 不放 KV
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-lingxi-dev
AZURE_LOCATION=southeastasia
AZURE_CONTAINER_APPS_ENV=cae-lingxi-dev
AZURE_STORAGE_ACCOUNT=stlingxilaifu
AZURE_STORAGE_ACCOUNT_NFS=stnfslingxidev
AZURE_ACR_LOGIN_SERVER=acrlingxidev.azurecr.io
AZURE_ACR_NAME=acrlingxidev
HERMES_IMAGE_TAG=latest
HERMES_MODEL=anthropic/claude-sonnet-4-6

# prod: ANTHROPIC_API_KEY / DASHSCOPE_API_KEY 走 KV; dev 走 local hermes 时
# 这些 key 配在 images/hermes/.env (供 docker run --env-file 用), 不是这里


# ── Session ─────────────────────────────────────────────────────────────
# dev:  随便填 (注意至少 32 字节, 否则 [config] 会警告)
# prod: KV secret session-secret, 用 openssl rand -hex 32 生成
SESSION_SECRET=change-me-to-32-byte-random-hex
SESSION_COOKIE_NAME=lingxi_sid
SESSION_TTL_HOURS=168


# ── Auth 同源/跨端口 ────────────────────────────────────────────────────
# OAuth 跳转地址由 PUBLIC_BASE_URL 决定 (gateway 拼 redirect_uri 用), 跳回前端用 FRONTEND_BASE_URL.
#
# dev:  跨端口 — gateway :9000, web :3000 (Vite)
#       PUBLIC_BASE_URL=http://localhost:9000
#       FRONTEND_BASE_URL=http://localhost:3000
#
# prod: 同进程同域 — gateway 托管 web/dist, 无跨域
#       PUBLIC_BASE_URL=https://<host>.azurewebsites.net
#       FRONTEND_BASE_URL=https://<host>.azurewebsites.net   (或留空走相对路径)
#       bicep 已自动用 defaultHostName 填这两个
PUBLIC_BASE_URL=http://localhost:9000
FRONTEND_BASE_URL=http://localhost:3000


# ── OAuth providers ─────────────────────────────────────────────────────
# 至少一个 provider 的 CLIENT_ID + CLIENT_SECRET 都填了, 否则 gateway 启动报错.
#
# Google OAuth (https://console.cloud.google.com → Credentials → Web application):
#   Authorized JavaScript origins:
#     http://localhost:3000                      (dev 前端)
#     https://<host>.azurewebsites.net           (prod)
#   Authorized redirect URIs (两个都加, 不要替换):
#     http://localhost:9000/api/auth/google/callback         (dev)
#     https://<host>.azurewebsites.net/api/auth/google/callback   (prod)
#
# dev/prod 可以共用同一对 client_id/secret (Google 允许多 redirect URI);
# 也可以为 prod 单独建一对, 隔离更干净.
# prod: KV secret google-client-id / google-client-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
