{
  "name": "lingxi",
  "version": "0.0.1",
  "private": true,
  "description": "灵犀 — 数字员工平台 monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "build:deploy": "scripts/build-deploy.sh",
    "start": "node apps/gateway/dist/index.js",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev": "concurrently -n hermes,gateway,web -c yellow,cyan,magenta --kill-others-on-fail \"pnpm dev:hermes\" \"pnpm dev:gateway\" \"pnpm dev:web\"",
    "dev:hermes": "node scripts/dev-hermes.mjs",
    "dev:gateway": "cd apps/gateway && cross-env DOTENV_CONFIG_PATH=.env.local pnpm exec tsx -r dotenv/config src/entry.ts",
    "dev:web": "pnpm --filter @lingxi/web dev",
    "dev:desktop": "pnpm --filter @lingxi/desktop dev",
    "dev:desktop:canary": "pnpm --filter @lingxi/desktop dev:canary",
    "dev:desktop:stable": "pnpm --filter @lingxi/desktop dev:stable",
    "desktop:fetch-rclone": "node scripts/fetch-rclone.mjs",
    "desktop:version": "node scripts/desktop-version.mjs",
    "dev:check": "scripts/dev-check.sh"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.4.0"
  }
}
