# Hermes container 运行所需 env
# 实际内容由 docker run --env-file 注入,或 Azure Container App 用 secret 注入

# Anthropic Claude (model: anthropic/claude-sonnet-4-6)
# 申请: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# 可选:覆盖 session 默认值
# HERMES_DEFAULT_SESSION=main
# HERMES_DEFAULT_SOURCE=web
# HERMES_TIMEOUT=300
