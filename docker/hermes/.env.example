# Hermes container 运行所需 env
# 实际内容由 docker run --env-file 注入,或 Azure Container App 用 secret 注入

# DashScope / 阿里云通义千问 (兼容 OpenAI 协议)
# 申请: https://dashscope.console.aliyun.com/
OPENAI_API_KEY=sk-your-dashscope-key

# 可选:覆盖 session 默认值
# HERMES_DEFAULT_SESSION=main
# HERMES_DEFAULT_SOURCE=web
# HERMES_TIMEOUT=300
