# Hermes container env
# 实际值由 docker run --env-file 注入,或 Azure Container App 用 secret 注入

# ── LLM provider / model ───────────────────────────────────────────
# 改 provider/model 不需要重 build 镜像 — entrypoint.sh 每次启动按 env 渲染 config.yaml。
#
# provider 填 Hermes 一等公民名 (alibaba / anthropic / openai / deepseek / xai ...)
# 完整列表: https://hermes-agent.nousresearch.com/docs/integrations/providers
#
# 常见组合:
#   anthropic + claude-sonnet-4-5-20250929   Claude Sonnet (国外, 推荐)
#   anthropic + claude-haiku-4-5             Claude Haiku  (国外, 便宜)
#   alibaba   + qwen3-coder-plus            通义千问 (国内, DashScope)

HERMES_PROVIDER=alibaba
HERMES_MODEL=qwen3-coder-plus

# 对应 provider 的 API key
#   anthropic: https://console.anthropic.com/settings/keys
#   alibaba (DashScope): https://dashscope.console.aliyun.com/
HERMES_API_KEY=

# HERMES_BASE_URL: provider=custom 时必填; 其余 provider 留空走默认官方 endpoint。
# ⚠️ alibaba 例外: 默认 endpoint 是国际站 (dashscope-intl), 而 dashscope.console.aliyun.com
#    申请的是国内站(CN) key, 留空会 401 invalid_api_key。国内站 key 必须显式指定:
#    HERMES_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#HERMES_BASE_URL=

# HERMES_VISION_MODEL: 主模型不吃原生图时, auxiliary.vision 走的专用 VL 模型 (alibaba=qwen-vl-max)。
# 容器 renderConfigYaml 把它写进 config.yaml; 仅当 HERMES_BASE_URL 在场时才生效 (端点覆盖保证)。
# 留空 = 不配 auxiliary.vision。prod 由 gateway HERMES_VISION_MODEL env 注入, 默认 qwen-vl-max。
HERMES_VISION_MODEL=qwen-vl-max

# ── Hermes 默认行为 (可选) ────────────────────────────────────────
# HERMES_DEFAULT_SESSION=main
# HERMES_DEFAULT_SOURCE=web
# HERMES_TIMEOUT=300
