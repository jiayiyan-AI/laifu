# Hermes container env
# 实际值由 docker run --env-file 注入,或 Azure Container App 用 secret 注入

# ── 选哪个模型 ──────────────────────────────────────────────────────
# anthropic/claude-sonnet-4-6  Claude Sonnet 4.6 (推荐,国外)
# anthropic/claude-haiku-4-5   Claude Haiku 4.5 (便宜,国外)
# qwen-plus / qwen-max          通义千问 (国内,走 DashScope)
HERMES_MODEL=anthropic/claude-sonnet-4-6

# ── Anthropic key ──────────────────────────────────────────────────
# 申请: https://console.anthropic.com/settings/keys
# HERMES_MODEL 选 anthropic/* 时必须填
ANTHROPIC_API_KEY=

# ── DashScope key ──────────────────────────────────────────────────
# 申请: https://dashscope.console.aliyun.com/
# HERMES_MODEL 选 qwen-* 时必须填
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Hermes 默认行为 (可选) ────────────────────────────────────────
# HERMES_DEFAULT_SESSION=main
# HERMES_DEFAULT_SOURCE=web
# HERMES_TIMEOUT=300
